#!/usr/bin/env bash

# Resolve paths
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$SELF_DIR/../lib/slash-env.sh" ]]; then
    source "$SELF_DIR/../lib/slash-env.sh"
elif [[ -f "/usr/lib/slash/slash-env.sh" ]]; then
    source "/usr/lib/slash/slash-env.sh"
elif [[ -f "/data/data/com.termux/files/usr/lib/slash/slash-env.sh" ]]; then
    source "/data/data/com.termux/files/usr/lib/slash/slash-env.sh"
else
    echo "Error: slash-env.sh not found."
    exit 1
fi

# Write PID
echo $$ > "$PID_FILE"

# Detect package manager
_detect_pkgmgr() {
    for mgr in pacman apt dnf apk pkg; do
        command -v "$mgr" >/dev/null 2>&1 && echo "$mgr" && return
    done
    echo "unknown"
}
PKG_MGR=$(_detect_pkgmgr)

# Build package cache
update_pkg_cache() {
    case "$PKG_MGR" in
        pacman) pacman -Slq > "$PKG_CACHE" 2>/dev/null ;;
        apt)    apt-cache pkgnames > "$PKG_CACHE" 2>/dev/null ;;
        dnf)    dnf list all -q | awk '{print $1}' > "$PKG_CACHE" 2>/dev/null ;;
        apk)    apk search -q > "$PKG_CACHE" 2>/dev/null ;;
        pkg)    pkg list-all | awk -F/ '{print $1}' > "$PKG_CACHE" 2>/dev/null ;;
    esac
}

# Build tools cache
update_tools_cache() {
    jq -r 'keys[]' "$TOOL_REGISTRY" | while read -r bin; do
        command -v "$bin" >/dev/null 2>&1 && echo "$bin"
    done > "$TOOLS_CACHE"
}

# Initial build
update_pkg_cache
update_tools_cache

# Loop
while true; do
    sleep 3600
    update_tools_cache
    # Update pkg cache once a day
    [[ $(date +%H) == "00" ]] && update_pkg_cache
done
