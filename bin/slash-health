#!/usr/bin/env bash

# Resolve paths
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$SELF_DIR/../lib/slash-env.sh" ]]; then
    source "$SELF_DIR/../lib/slash-env.sh"
elif [[ -f "/usr/lib/slash/slash-env.sh" ]]; then
    source "/usr/lib/slash/slash-env.sh"
elif [[ -f "/data/data/com.termux/files/usr/lib/slash/slash-env.sh" ]]; then
    source "/data/data/com.termux/files/usr/lib/slash/slash-env.sh"
else
    echo "Error: slash-env.sh not found."
    exit 1
fi

echo -e "\033[1;36m--- xzp-slash System Health ---\033[0m"
echo "Environment: $( [[ "$IS_TERMUX" == true ]] && echo "Termux" || echo "Linux" )"
echo "Prefix: $PREFIX"
echo "Config: $SLASH_ETC"
echo "User Config: $SLASH_USER_CONFIG"
echo

echo -e "\033[1;33mChecking Tools:\033[0m"
TOOLS=$(jq -r 'keys[]' "$TOOL_REGISTRY")
TOOLS+=" node yarn clang gcc rustc zsh tree zip unzip openssh"

for tool in $TOOLS; do
    if command -v "$tool" >/dev/null 2>&1; then
        echo -e "\033[1;32m[OK]\033[0m $tool"
    else
        echo -e "\033[1;31m[MISSING]\033[0m $tool"
    fi
done

echo
echo -e "\033[1;33mChecking PATH:\033[0m"
for p in "$HOME/bin" "$HOME/.local/bin" "$PREFIX/bin"; do
    if [[ ":$PATH:" == *":$p:"* ]]; then
        echo -e "\033[1;32m[IN PATH]\033[0m $p"
    else
        echo -e "\033[1;31m[NOT IN PATH]\033[0m $p"
    fi
done
